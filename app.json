{
  "expo": {
    "name": "Huella",
    "slug": "huella",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "huella",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.huella.app",
      "config": {
        "googleMapsApiKey": "AIzaSyD3gsEL2fhhJ7KoqBwtcgoD6MO0V6jCQqM"
      }
    },
    "android": {
      "package": "com.huella.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD3gsEL2fhhJ7KoqBwtcgoD6MO0V6jCQqM"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permite que Huella acceda a tu ubicación para mostrar casos cercanos."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "076b7909-324a-4fc3-b531-e364491fb623"
      }
    }
  }
}
